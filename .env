# Hermes Folder Path Configuration
# Specify the full path to your Hermes folder here
# Examples:
#   - macOS/Linux: /home/user/.hermes or /Users/user/.hermes or ~/.hermes
#   - Windows: C:\Users\user\.hermes or C:\Hermes

# Leave empty to use the relative path resolution (if running from tools/hc within Hermes)
# HERMES_PATH=
